{
  "scopeName": "source.azlang",
  "patterns": [
    {
      "name": "keyword.control.azlang",
      "match": "\\b(funksiya|qaytar|Çap)\\b"
    },
    {
      "name": "storage.type.azlang",
      "match": "\\b(ədəd|çağrılan|yazı|sabit)\\b"
    },
    {
      "name": "entity.name.function.azlang",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\()"
    },
    {
      "name": "variable.parameter.azlang",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
    },
    {
      "name": "constant.numeric.azlang",
      "match": "\\b\\d+\\b"
    },
    {
      "name": "keyword.operator.azlang",
      "match": "[+\\-*/=]"
    }
  ]
}